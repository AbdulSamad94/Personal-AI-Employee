# Copy this file to .env and fill in your own values. Never commit .env itself.

# Master safety switch — keep true until you've reviewed what the agent does.
# When true, watchers/MCP servers log intended actions instead of sending/posting for real.
DRY_RUN=true

# --- Gmail (personal / default account) ---
# GMAIL_USER: the Gmail address itself.
# GMAIL_APP_PASSWORD: a Google App Password (myaccount.google.com/apppasswords),
#   NOT your regular account password. Requires 2FA enabled on the account.
GMAIL_USER=
GMAIL_APP_PASSWORD=

# --- Gmail (optional second account, e.g. a work/job-search inbox) ---
# Only needed if you're running gmail_watcher.py with GMAIL_ACCOUNT_LABEL=work.
# See CONTRIBUTING.md for the OAuth "test user" gotcha if you hit a 403 on first run.
GMAIL_USER_WORK=
GMAIL_APP_PASSWORD_WORK=

# --- LinkedIn ---
LINKEDIN_TOKEN=
LINKEDIN_PERSON_ID=

# --- Telegram approval bot (optional — see CONTRIBUTING.md for BotFather setup) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Discord approval bot (optional — redundant channel, see CONTRIBUTING.md) ---
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# --- Odoo accounting (optional — NOT safe to enable yet, see AGENTS.md Known Issues) ---
ODOO_URL=
ODOO_DB=
ODOO_USER=
ODOO_PASSWORD=
ODOO_MASTER_PASSWORD=
